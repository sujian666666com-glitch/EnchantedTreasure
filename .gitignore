# EnchantedTreasure .gitignore

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Thumbnails
*.Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/
out/

# Environment files
.env
.env.local
.env.*.local

# Sensitive files
*.pem
*.key
*.p12
secrets/
credentials/

# Large files (use Git LFS instead)
*.zip
*.rar
*.7z
*.tar.gz

# Media files (optional, uncomment if needed)
# *.mp4
# *.mov
# *.avi

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# OS generated
ehthumbs.db
desktop.ini