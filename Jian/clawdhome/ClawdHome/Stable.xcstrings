      }
    },
    "process.desc.kernel_task": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS kernel task — manages hardware and low-level system resources."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacOS 内核任务，管理硬件与系统底层资源。"
          }
        }
      }
    },
    "process.desc.launchd": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS init and daemon manager — launches and supervises background services."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacOS 系统初始化与守护进程管理器，负责拉起后台服务。"
          }
        }
      }
    },
    "process.desc.logd": {
      "extractionState": "manual",
