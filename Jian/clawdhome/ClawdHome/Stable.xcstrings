    "process.desc.cfprefsd": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS preferences daemon — reads and writes per-app preference caches."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacOS 系统偏好设置守护进程，负责读写配置缓存。"
          }
        }
      }
    },
    "process.desc.distnoted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS distributed notification service — handles cross-process notifications."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacOS 系统通知分发服务，负责跨进程通知通信。"
          }
