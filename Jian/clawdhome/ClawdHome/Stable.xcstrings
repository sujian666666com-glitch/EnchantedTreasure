    "user.detail.alert.logout.message": {
      "comment": "",
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will stop Gateway and sign out this user session (launchctl bootout).\n\nUser data will not be deleted; Gateway can be started again at any time."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将停止 Gateway 并退出该用户的登录会话（launchctl bootout）。\n\n用户数据不会被删除，可随时重新启动 Gateway。"
          }
        }
      }
    },
